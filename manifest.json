{
  "manifest_version": 3,
  "name": "Improve with GPT",
  "version": "1.0.0",
  "description": "Right-click any textarea to improve text with GPT",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": ["https://api.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
